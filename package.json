{
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TSDoc extraction and Nuxt consumption for @kagal packages",
  "author": "Apptly Software Ltd <oss@apptly.co>",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rimraf node_modules",
    "cspell": "cspell --config internal/build/cspell.json --gitignore --no-progress '**'",
    "dev:prepare": "pnpm -r dev:prepare",
    "lint": "run-s lint:root cspell lint:_packages",
    "lint:_packages": "pnpm -r lint",
    "lint:check": "run-s lint:root:check cspell lint:check:_packages",
    "lint:check:_packages": "pnpm -r lint:check",
    "lint:root": "eslint --fix --ignore-pattern 'packages/*' .",
    "lint:root:check": "eslint --ignore-pattern 'packages/*' .",
    "precommit": "run-s dev:prepare lint type-check build test",
    "prepack": "run-s lint:root:check && pnpm -r prepack",
    "test": "pnpm -r test",
    "test:compat": "pnpm -r test:compat",
    "test:coverage": "pnpm -r test:coverage",
    "type-check": "run-s type-check:root type-check:packages",
    "type-check:packages": "pnpm -r type-check",
    "type-check:root": "tsc --noEmit -p tsconfig.tools.json"
  },
  "devDependencies": {
    "@poupe/eslint-config": "~0.9.1",
    "@types/node": "^20.19.37",
    "cspell": "^10.0.0",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "pkg-pr-new": "^0.0.71",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
