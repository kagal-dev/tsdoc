{
  "name": "@kagal/vue-tsdoc",
  "version": "0.0.0",
  "type": "module",
  "description": "Vue components for rendering api-extractor-model graphs",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/kagal-dev/tsdoc/tree/main/packages/@kagal-vue-tsdoc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kagal-dev/tsdoc.git",
    "directory": "packages/@kagal-vue-tsdoc"
  },
  "bugs": {
    "url": "https://github.com/kagal-dev/tsdoc/issues"
  },
  "keywords": [
    "api-extractor",
    "kagal",
    "tsdoc",
    "vue"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "clean": "rimraf dist node_modules",
    "dev": "vite",
    "dev:prepare": "obuild --stub",
    "lint": "eslint --fix .",
    "lint:_pkg-pr-new": "eslint --fix package.json",
    "lint:check": "eslint .",
    "precommit": "run-s dev:prepare lint type-check build test",
    "prepack": "run-s lint:_pkg-pr-new lint:check type-check build test publint",
    "prepare": "cross-test -s dist/index.mjs || pnpm dev:prepare",
    "publint": "publint",
    "publish:maybe": "npm view ${npm_package_name}@${npm_package_version} version 2>/dev/null && echo \"${npm_package_name}@${npm_package_version} already published\" || pnpm publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@microsoft/api-extractor-model": "^7.33.8"
  },
  "devDependencies": {
    "@kagal/cross-test": "^0.1.3",
    "@microsoft/api-extractor": "^7.58.9",
    "@microsoft/tsdoc": "^0.16.0",
    "@poupe/eslint-config": "^0.10.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.43",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^9.0.2",
    "obuild": "^0.4.34",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "unplugin-vue": "^6.2.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.9",
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.2"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "engines": {
    "node": ">= 20.20.1",
    "pnpm": ">= 10.33.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
